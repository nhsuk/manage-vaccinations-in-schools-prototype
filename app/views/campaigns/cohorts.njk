{% extends "_layouts/default.njk" %}

{% set paths = { back: "/home" } if data.token.role == UserRole.DataConsumer %}
{% set title = campaign.type + " – " + __("campaign.cohorts.title") %}
{% set view = "cohorts" %}

{% block beforeContent %}
  {{ breadcrumb({
    items: [{
      text: __("campaign.list.title"),
      href: "/campaigns"
    }],
    text: campaign.type,
    href: campaign.uri
  }) }}
{% endblock %}

{% block content %}
  {{ super() }}

  {{ heading({
    title: campaign.type,
    summary: campaign.year
  }) }}

  {% include "campaigns/_secondary-navigation.njk" %}

  <h2 class="nhsuk-heading-m nhsuk-u-visually-hidden">
    {{ __("campaign.cohorts.title") }}
  </h2>

  {{ actionList({
    items: [{
      href: campaign.uri + "/cohorts/new",
      text: __("cohort.new.label")
    }]
  }) if data.token.role != UserRole.DataConsumer }}

  {% if cohorts.length %}
  <ul class="nhsuk-grid-row nhsuk-card-group">
    {% for cohort in cohorts %}
    <li class="nhsuk-grid-column-one-third nhsuk-card-group__item">
      {{ card({
        clickable: true,
        heading: cohort.formatted.yearGroups,
        headingClasses: "nhsuk-heading-m",
        href: cohort.uri,
        descriptionHtml: __n("cohort.records.count", cohort.records.length)
      }) }}
    </li>
    {% endfor %}
  </ul>
  {% else %}
    {{ __n("cohort.records.count", cohort.records.length) | nhsukMarkdown }}
  {% endif %}
{% endblock %}
