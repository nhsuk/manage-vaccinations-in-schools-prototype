{% from "programme/_navigation.njk" import programmeNavigation with context %}

{% extends "_layouts/default.njk" %}

{% set isDataConsumer = data.token.role == UserRole.DataConsumer %}
{% set paths = { back: "/home" } if isDataConsumer %}
{% set title = programme.name + " – " + __("programme.show.title") %}

{% block beforeContent %}
  {{ breadcrumb({
    items: [{
      text: __("home.show.title"),
      href: "/"
    }],
    text: __("programme.list.title"),
    href: "/programmes"
  }) if data.token.role != UserRole.DataConsumer }}
{% endblock %}

{% block content %}
  {{ super() }}

  {{ programmeNavigation({
    isDataConsumer: isDataConsumer,
    programme: programme,
    view: "show"
  }) }}

  <div class="nhsuk-grid-row nhsuk-card-group">
    <div class="nhsuk-grid-column-one-third nhsuk-card-group__item">
      {{ card({
        classes: "app-card--data app-card--reversed-green",
        clickable: true if not isDataConsumer,
        heading: PatientOutcome.Vaccinated,
        headingClasses: "nhsuk-heading-xs",
        href: programme.uri + "/patients?outcome=" + PatientOutcome.Vaccinated if not isDataConsumer,
        description: programme.outcome(PatientOutcome.Vaccinated).length or "0"
      }) }}
    </div>

    <div class="nhsuk-grid-column-one-third nhsuk-card-group__item">
      {{ card({
        classes: "app-card--data app-card--reversed-red",
        clickable: true if not isDataConsumer,
        heading: PatientOutcome.CouldNotVaccinate,
        headingClasses: "nhsuk-heading-xs",
        href: programme.uri + "/patients?outcome=" + PatientOutcome.CouldNotVaccinate if not isDataConsumer,
        description: programme.outcome(PatientOutcome.CouldNotVaccinate).length or "0"
      }) }}
    </div>

    <div class="nhsuk-grid-column-one-third nhsuk-card-group__item">
      {{ card({
        classes: "app-card--data app-card--reversed-grey",
        clickable: true if not isDataConsumer,
        heading: PatientOutcome.NoOutcomeYet,
        headingClasses: "nhsuk-heading-xs",
        href: programme.uri + "/patients?outcome=" + PatientOutcome.NoOutcomeYet if not isDataConsumer,
        description: programme.outcome(PatientOutcome.NoOutcomeYet).length or "0"
      }) }}
    </div>
  </div>

  {{ actionLink({
    text: __("download.new.label"),
    href: programme.uri + "/download/new"
  }) if programme.vaccinations.length }}

  {{ heading({
    level: 2,
    size: "m",
    title: __("programme.show.cohorts")
  }) }}

  <ul class="nhsuk-grid-row nhsuk-card-group">
  {% for cohort in programme.cohorts | sort(false, false, "yearGroup") %}
    <li class="nhsuk-grid-column-one-quarter nhsuk-card-group__item">
      {{ card({
        clickable: true,
        heading: cohort.formatted.yearGroup,
        headingClasses: "nhsuk-heading-m",
        href: programme.uri + "/patients?yearGroup=" + cohort.yearGroup,
        descriptionHtml: __n("cohort.patients.count", cohort.patients.length)
      }) }}
    </li>
  {% endfor %}
  </ul>

{% if programme.sessions.length %}
  {{ heading({
    level: 2,
    size: "m",
    title: __("programme.show.responses")
  }) }}

  <div class="nhsuk-grid-row nhsuk-card-group">
    <div class="nhsuk-grid-column-one-third nhsuk-card-group__item">
      {{ card({
        classes: "app-card--data",
        heading: "Consent requests and reminders sent",
        headingClasses: "nhsuk-heading-xs",
        description: 1671
      }) }}
    </div>

    <div class="nhsuk-grid-column-one-third nhsuk-card-group__item">
      {{ card({
        classes: "app-card--data",
        heading: "Consent given (versus refused or no response)",
        headingClasses: "nhsuk-heading-xs",
        description: "78%"
      }) }}
    </div>

    <div class="nhsuk-grid-column-one-third nhsuk-card-group__item">
      {{ card({
        classes: "app-card--data",
        heading: "Responses received and triaged",
        headingClasses: "nhsuk-heading-xs",
        description: "98%"
      }) }}
    </div>
  </div>

  {{ table({
    heading: "Reasons for refusal",
    panel: true,
    head: [
      { text: __("reply.refusalReason.label") },
      { text: "Frequency", format: "numeric" }
    ],
    rows: [
      [
        { text: ReplyRefusal.Gelatine },
        { text: "11.1%", format: "numeric" }
      ] if programme.type == ProgrammeType.Flu,
      [
        { text: ReplyRefusal.AlreadyGiven },
        { text: "2.0%", format: "numeric" }
      ],
      [
        { text: ReplyRefusal.GettingElsewhere },
        { text: "3.6%", format: "numeric" }
      ],
      [
        { text: ReplyRefusal.Medical },
        { text: "1.0%", format: "numeric" }
      ],
      [
        { text: ReplyRefusal.Personal },
        { text: "5.1%", format: "numeric" }
      ],
      [
        { text: ReplyRefusal.Other },
        { text: "1.1%", format: "numeric" }
      ]
    ]
  }) }}

  {% set questionRows = [] %}
  {% for healthQuestion in programme.vaccine.healthQuestions %}
    {% set questionRows = questionRows | push([
      {
        text: healthQuestion
      },
      {
        text: ["0.21","0.57","3.45","1.89"] | random + "%",
        format: "numeric"
      }
    ]) %}
  {% endfor %}

  {{ table({
    heading: "Consent journey",
    panel: true,
    head: [
      { text: "Question" },
      { html: "Dropout", format: "numeric" }
    ],
    rows: questionRows
  }) }}
{% endif %}
{% endblock %}
