{% from "_macros/session-search.njk" import sessionSearch with context %}

{% extends "_layouts/default.njk" %}

{% set title = __("session.list.title") %}
{% set showDates = view == "planned" or view == "completed" %}

{% block content %}
  {{ super() }}

  {{ heading({
    size: "xl",
    title: __("session.list.title")
  }) }}

  <div class="nhsuk-grid-row">
    <auto-submit class="app-grid-column-filters">
      {{ sessionSearch({
        clear: "/sessions",
        status: "status"
      }) }}
    </auto-submit>

    <div class="app-grid-column-results">
      {{ heading({
        level: 3,
        size: "m",
        title: title | replace(",", " or "),
        summary: __mf("session.results", {
          from: results.from,
          to: results.to,
          count: results.count
        }) | safe
      }) }}

      {{ button({
        classes: "nhsuk-button--secondary",
        text: __("session.new.label"),
        href: "/sessions/new"
      }) }}

      {% for session in results.page %}
        {{ card({
          classes: "app-card--result",
          heading: session.location.name | highlightQuery(data.q),
          headingClasses: "nhsuk-heading-s",
          headingLevel: 4,
          href: session.uri,
          clickable: true,
          descriptionHtml: summaryList({
            rows: summaryRows(session, {
              patients: {},
              programmes: {},
              dates: {},
              consentWindow: {},
              status: {}
            })
          })
        }) }}
      {% endfor %}

      {{ govukPagination(pages) }}
    </div>
  </div>
{% endblock %}
