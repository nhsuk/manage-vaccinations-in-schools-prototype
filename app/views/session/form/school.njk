{% extends "_layouts/form.njk" %}

{% set title = __("session.school.title") %}

{% block form %}
  {{ heading({
    title: title
  }) }}

  {{ autocomplete({
    id: "school-urn",
    name: "[session][school_urn]",
    value: session.school_urn,
    label: { text: __("session.school_urn.title") },
    items: schoolItems(data.schools, session.school_urn)
  }) }}
{% endblock %}
