{% extends "_layouts/form.njk" %}

{% set title = __("patient.school.title") %}

{% block form %}
  {{ autocomplete({
    id: "school-urn",
    name: "[patient][school_urn]",
    value: patient.school_urn,
    label: {
      classes: "nhsuk-label--l",
      html: heading({
        caption: patient.fullName,
        title: title
      })
    },
    items: schoolItems(data.schools, patient.school_urn)
  }) }}
{% endblock %}
