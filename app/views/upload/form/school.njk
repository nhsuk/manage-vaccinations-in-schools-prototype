{% extends "_layouts/form.njk" %}

{% set title = __("upload.school.title") %}

{% block form %}
  {{ autocomplete({
    id: "school-urn",
    name: "[upload][school_urn]",
    value: upload.school_urn,
    label: {
      html: heading({
        title: title
      })
    },
    items: schoolItems(data.schools, upload.school_urn)
  }) }}
{% endblock %}
