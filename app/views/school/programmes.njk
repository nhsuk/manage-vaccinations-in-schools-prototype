{% from "school/_navigation.njk" import schoolNavigation with context %}

{% extends "_layouts/form.njk" %}

{% set gridColumns = "full" %}
{% set hideConfirmButton = true %}
{% set title = school.name + " – " + __("school.programmes.title") %}

{% block beforeContent %}
  {{ breadcrumb({
    items: [{
      text: __("home.show.title"),
      href: "/"
    }, {
      text: __("school.list.title"),
      href: "/schools"
    }],
    text: __("school.programmes.title"),
    href: school.url + "/programmes"
  }) }}
{% endblock %}

{% block form %}
  {{ super() }}

  {{ schoolNavigation({
    school: school,
    view: "programmes"
  }) }}

  {% for programme in school.programmes %}
    {{ appHeading({
      title: programme.name,
      level: 3,
      size: "m"
    }) }}

    {{ programme.formatted.consentPdf | nhsukMarkdown }}
  {% endfor %}
{% endblock %}
